class Solution:
    def containsDuplicate(self, nums: List[int]) -> bool:
        # dict_ = {index: value for index, value in enumerate(nums)}
        numbers = set()

        for integer in nums:
            # numbers.append(integer)
            if integer in numbers:
                return True
            numbers.add(integer)  ## there is no append in set, only add
            
        return False
            
